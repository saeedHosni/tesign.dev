// ─── TICKET SYSTEM ────────────────────────────────────────────────────────────
// این بخش را به انتهای prisma/schema.prisma اضافه کنید
// همچنین به مدل User باید relations زیر اضافه شوند:
//
//   tickets        Ticket[]          // در مدل User
//   ticketMessages TicketMessage[]   // در مدل User
//
// و به مدل Order:
//   tickets        Ticket[]          // در مدل Order

enum TicketDepartment {
  SUPPORT    // پشتیبانی عمومی
  TECHNICAL  // بخش فنی
  SALES      // بخش فروش
  ORDER      // درباره سفارش خاص
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN      // باز — در انتظار پاسخ ادمین
  ANSWERED  // پاسخ داده شده توسط ادمین
  PENDING   // در انتظار پاسخ کاربر
  CLOSED    // بسته شده
}

model Ticket {
  id           String             @id @default(uuid())
  ticketNumber String             @unique  // TK-YYYYMM-XXXX
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId      String?
  order        Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  department   TicketDepartment   @default(SUPPORT)
  priority     TicketPriority     @default(MEDIUM)
  status       TicketStatus       @default(OPEN)
  subject      String
  assignedTo   String?            // ID ادمین پاسخ‌دهنده
  closedAt     DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  messages     TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderId])
  @@map("tickets")
}

model TicketMessage {
  id          String              @id @default(uuid())
  ticketId    String
  ticket      Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderRole  String              // 'CUSTOMER' | 'ADMIN' | 'MANAGER'
  body        String
  isInternal  Boolean             @default(false)  // یادداشت داخلی — فقط ادمین می‌بینه
  createdAt   DateTime            @default(now())

  attachments TicketAttachment[]

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id           String         @id @default(uuid())
  messageId    String
  message      TicketMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename     String
  originalName String?
  url          String
  mimetype     String?
  size         Int?
  createdAt    DateTime       @default(now())

  @@index([messageId])
  @@map("ticket_attachments")
}
